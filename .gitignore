import random

def task_1():
    name = input("Введіть ваше ім'я: ")
    age = input("Введіть ваш вік: ")
    print(f"Привіт {name}, тобі {age}!")

def task_2():
    age = int(input("Введіть ваш вік: "))
    if age > 18:
        print("Вхід дозволено!")
    else:
        print("Вхід заборонено!")

def task_3():
    target = random.randint(1, 10)
    attempts = 3
    print("\nГра 'Вгадай число' (від 1 до 10). У вас 3 спроби.")
    
    for i in range(attempts):
        guess = int(input(f"Спроба {i+1}. Ваше число: "))
        if guess == target:
            print("Ви вгадали!")
            return
        elif guess > target:
            print("Менше")
        else:
            print("Більше")
    print(f"Ви програли. Загадане число було: {target}")

def task_4():
    start = int(input("Введіть число 'З': "))
    end = int(input("Введіть число 'ПО': "))
    for i in range(start, end + 1):
        print(i, end=" ")
    print()

def task_5():
    n = int(input("Введіть число n: "))
    print(f"Парні числа від 1 до {n} у зворотному порядку:")
    for i in range(n, 0, -1):
        if i % 2 == 0:
            print(i, end=" ")
    print()

def task_6():
    n = int(input("Введіть число n для обчислення факторіалу: "))
    factorial = 1
    if n < 0:
        print("Факторіал від'ємного числа не існує.")
    else:
        for i in range(1, n + 1):
            factorial *= i
        print(f"!{n} = {factorial}")

def task_7():
    score = int(input("Введіть кількість балів (0-100): "))
    if 0 <= score <= 49:
        print("Незадовільно")
    elif 50 <= score <= 69:
        print("Задовільно")
    elif 70 <= score <= 89:
        print("Добре")
    elif 90 <= score <= 100:
        print("Відмінно")
    else:
        print("Некоректна кількість балів")

def task_8():
    a = float(input("Введіть перше число (a): "))
    b = float(input("Введіть друге число (b): "))
    action = input("Вкажіть математичну дію (+, -, *, /): ")
    
    if action == "+":
        print(f"Результат: {a + b}")
    elif action == "-":
        print(f"Результат: {a - b}")
    elif action == "*":
        print(f"Результат: {a * b}")
    elif action == "/":
        if b == 0:
            print("Ділення на нуль")
        else:
            print(f"Результат: {a / b}")
    else:
        print("Невідома операція")

if __name__ == "__main__":
    # Ви можете просто викликати потрібну функцію, наприклад:
    # task_1()
    # Або запустити по черзі всі за потреби.
    print("Програма готова. Виберіть завдання (1-8):")
    choice = input("Номер завдання: ")
    
    tasks = {
        "1": task_1, "2": task_2, "3": task_3, "4": task_4,
        "5": task_5, "6": task_6, "7": task_7, "8": task_8
    }
    
    if choice in tasks:
        tasks[choice]()
    else:
        print("Такого завдання немає.")
